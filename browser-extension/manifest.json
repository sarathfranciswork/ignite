{
  "manifest_version": 3,
  "name": "Ignite Web Clipper",
  "version": "1.0.0",
  "description": "Clip web content into Ignite as trends, insights, or idea inspiration.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
