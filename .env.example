# Database
DATABASE_URL="postgresql://ignite:ignite@localhost:5432/ignite"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# S3-compatible storage (MinIO in development)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="ignite"

# AI Configuration
# AI_ENABLED=true (default) uses local ONNX embeddings
# Set OPENAI_API_KEY to use OpenAI embeddings instead
# Set AI_ENABLED=false to disable AI features entirely
AI_ENABLED="true"
# OPENAI_API_KEY=""

# Email (Mailpit in development)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="noreply@ignite.local"

# Node environment
NODE_ENV="development"
