# Ignite - Environment Variables
# Copy to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URL="postgresql://ignite:ignite@localhost:5432/ignite?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication (NextAuth.js v5)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# S3-compatible Storage (MinIO for local dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ignite-files"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# AI Features (optional)
AI_ENABLED="false"
# OPENAI_API_KEY="sk-..."

# Email (Mailpit for local dev)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ignite <noreply@ignite.local>"

# GCP (production only)
# GCP_PROJECT_ID=""
# GCS_BUCKET=""
