# Database
DATABASE_URL=postgresql://innoflow:innoflow@localhost:5432/innoflow

# Redis
REDIS_URL=redis://localhost:6379

# SMTP (Mailpit defaults for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@innoflow.app

# App
APP_URL=http://localhost:3000
APP_NAME=InnoFlow

# Digest scheduling
DIGEST_DAILY_HOUR=8
DIGEST_WEEKLY_DAY=1
DIGEST_WEEKLY_HOUR=8
