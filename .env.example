# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ignite?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Crunchbase Integration (optional - configure in Admin > Integrations)
CRUNCHBASE_API_KEY=
CRUNCHBASE_API_BASE_URL="https://api.crunchbase.com/api/v4"

# App
NODE_ENV="development"
