// ─── Communication Hub ──────────────────────────────────────

enum CampaignMessageStatus {
  DRAFT
  SENT
  FAILED

  @@map("campaign_message_status")
}

enum AudienceSegment {
  ALL_MEMBERS
  CONTRIBUTORS
  NON_CONTRIBUTORS
  VIEWERS_NO_CONTRIBUTION
  SELECTED_IDEA_AUTHORS
  MANAGERS
  COACHES
  EVALUATORS
  SEEDERS
  SPONSORS
  CUSTOM_ROLE

  @@map("audience_segment")
}

model CampaignMessage {
  id         String                @id @default(cuid())
  campaignId String                @map("campaign_id")
  subject    String
  body       String                @db.Text
  segment    AudienceSegment       @default(ALL_MEMBERS)
  status     CampaignMessageStatus @default(DRAFT)
  sentAt     DateTime?             @map("sent_at")
  sentById   String                @map("sent_by_id")

  // Delivery stats
  recipientCount Int @default(0) @map("recipient_count")
  deliveredCount Int @default(0) @map("delivered_count")
  failedCount    Int @default(0) @map("failed_count")

  // Whether to also post to campaign activity feed
  postToFeed Boolean @default(true) @map("post_to_feed")

  // Whether to send email
  sendEmail Boolean @default(true) @map("send_email")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  campaign         Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sentBy           User               @relation("CampaignMessageSentBy", fields: [sentById], references: [id])
  communicationLog CommunicationLog[]

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([sentById])
  @@index([sentAt])
  @@map("campaign_messages")
}

enum CommunicationChannel {
  EMAIL
  IN_APP
  FEED

  @@map("communication_channel")
}

enum CommunicationStatus {
  PENDING
  DELIVERED
  FAILED

  @@map("communication_status")
}

model CommunicationLog {
  id        String               @id @default(cuid())
  messageId String               @map("message_id")
  userId    String               @map("user_id")
  channel   CommunicationChannel
  status    CommunicationStatus  @default(PENDING)
  error     String?              @db.Text
  sentAt    DateTime             @default(now()) @map("sent_at")

  // Relations
  message CampaignMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([userId])
  @@index([messageId, status])
  @@map("communication_logs")
}

// ── Webhook Models ──────────────────────────────────────────

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED

  @@map("webhook_status")
}

model Webhook {
  id          String        @id @default(cuid())
  name        String
  url         String
  secret      String
  status      WebhookStatus @default(ACTIVE)
  events      String[]      @default([])
  description String?       @db.Text
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdBy  User              @relation("WebhookCreatedBy", fields: [createdById], references: [id])
  deliveries WebhookDelivery[]

  @@index([createdById])
  @@index([status])
  @@map("webhooks")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED

  @@map("webhook_delivery_status")
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  webhookId      String                @map("webhook_id")
  eventName      String                @map("event_name")
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  httpStatusCode Int?                  @map("http_status_code")
  responseBody   String?               @map("response_body") @db.Text
  errorMessage   String?               @map("error_message") @db.Text
  attemptCount   Int                   @default(0) @map("attempt_count")
  nextRetryAt    DateTime?             @map("next_retry_at")
  deliveredAt    DateTime?             @map("delivered_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([webhookId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// ── API Key Models ──────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyPrefix   String    @map("key_prefix")
  keyHash     String    @unique @map("key_hash")
  scopes      String[]  @default([])
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy User @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])

  @@index([keyHash])
  @@index([createdById])
  @@index([isActive])
  @@map("api_keys")
}

// ── Concepts (Lightweight Phase-Gate) ───────────────────────

enum ConceptStatus {
  ELABORATION
  EVALUATION
  APPROVED
  REJECTED

  @@map("concept_status")
}

enum ConceptDecisionType {
  APPROVE
  REJECT
  REVISE

  @@map("concept_decision_type")
}

enum ConceptTeamRole {
  OWNER
  CONTRIBUTOR
  REVIEWER

  @@map("concept_team_role")
}

model Concept {
  id                   String        @id @default(cuid())
  title                String
  description          String?       @db.Text
  status               ConceptStatus @default(ELABORATION)
  ownerId              String        @map("owner_id")
  sourceIdeaId         String?       @map("source_idea_id")
  problemStatement     String?       @map("problem_statement") @db.Text
  proposedSolution     String?       @map("proposed_solution") @db.Text
  valueProposition     String?       @map("value_proposition") @db.Text
  swotStrengths        String?       @map("swot_strengths") @db.Text
  swotWeaknesses       String?       @map("swot_weaknesses") @db.Text
  swotOpportunities    String?       @map("swot_opportunities") @db.Text
  swotThreats          String?       @map("swot_threats") @db.Text
  targetMarket         String?       @map("target_market") @db.Text
  resourceRequirements String?       @map("resource_requirements") @db.Text
  expectedRoi          String?       @map("expected_roi") @db.Text
  riskAssessment       String?       @map("risk_assessment") @db.Text
  createdById          String        @map("created_by_id")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  owner            User                @relation("ConceptOwner", fields: [ownerId], references: [id])
  createdBy        User                @relation("ConceptCreatedBy", fields: [createdById], references: [id])
  sourceIdea       Idea?               @relation("ConceptSourceIdea", fields: [sourceIdeaId], references: [id], onDelete: SetNull)
  convertedProject Project?            @relation("ProjectSourceConcept")
  teamMembers      ConceptTeamMember[]
  decisions        ConceptDecision[]

  @@index([ownerId])
  @@index([createdById])
  @@index([sourceIdeaId])
  @@index([status])
  @@map("concepts")
}

model ConceptTeamMember {
  id        String          @id @default(cuid())
  conceptId String          @map("concept_id")
  userId    String          @map("user_id")
  role      ConceptTeamRole
  createdAt DateTime        @default(now()) @map("created_at")

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  user    User    @relation("ConceptTeamMember", fields: [userId], references: [id])

  @@unique([conceptId, userId])
  @@index([conceptId])
  @@index([userId])
  @@map("concept_team_members")
}

model ConceptDecision {
  id        String              @id @default(cuid())
  conceptId String              @map("concept_id")
  decision  ConceptDecisionType
  feedback  String?             @db.Text
  decidedBy String              @map("decided_by")
  createdAt DateTime            @default(now()) @map("created_at")

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@map("concept_decisions")
}

// ── Consensus Notes (One-Team Evaluation) ───────────────────

model ConsensusNote {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  ideaId    String   @map("idea_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author  User              @relation("ConsensusNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, ideaId])
  @@index([authorId])
  @@map("consensus_notes")
}

// ── Submission Definitions (Generic Submissions) ────────────

enum SubmissionDefinitionStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("submission_definition_status")
}

enum SubmissionFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  MULTI_SELECT
  DATE
  CHECKBOX
  FILE
  RICH_TEXT
  URL

  @@map("submission_field_type")
}

model SubmissionDefinition {
  id          String                     @id @default(cuid())
  name        String
  description String?                    @db.Text
  status      SubmissionDefinitionStatus @default(DRAFT)
  slug        String                     @unique
  campaignId  String?                    @map("campaign_id")
  isGlobal    Boolean                    @default(false) @map("is_global")
  createdById String                     @map("created_by_id")
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")

  campaign    Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy   User                @relation("SubmissionDefinitionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  fields      SubmissionField[]
  submissions GenericSubmission[]

  @@index([campaignId])
  @@index([status])
  @@index([createdById])
  @@map("submission_definitions")
}

model SubmissionField {
  id           String              @id @default(cuid())
  definitionId String              @map("definition_id")
  label        String
  fieldKey     String              @map("field_key")
  fieldType    SubmissionFieldType @map("field_type")
  isRequired   Boolean             @default(false) @map("is_required")
  sortOrder    Int                 @default(0) @map("sort_order")
  placeholder  String?
  helpText     String?             @map("help_text") @db.Text
  options      Json?
  validation   Json?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  definition SubmissionDefinition   @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  values     SubmissionFieldValue[]

  @@unique([definitionId, fieldKey])
  @@index([definitionId])
  @@index([definitionId, sortOrder])
  @@map("submission_fields")
}

enum GenericSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED

  @@map("generic_submission_status")
}

model GenericSubmission {
  id            String                  @id @default(cuid())
  definitionId  String                  @map("definition_id")
  title         String
  status        GenericSubmissionStatus @default(DRAFT)
  submittedById String                  @map("submitted_by_id")
  reviewedById  String?                 @map("reviewed_by_id")
  reviewNote    String?                 @map("review_note") @db.Text
  submittedAt   DateTime?               @map("submitted_at")
  reviewedAt    DateTime?               @map("reviewed_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  definition  SubmissionDefinition   @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  submittedBy User                   @relation("GenericSubmissionSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy  User?                  @relation("GenericSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  fieldValues SubmissionFieldValue[]

  @@index([definitionId])
  @@index([submittedById])
  @@index([reviewedById])
  @@index([status])
  @@index([definitionId, status])
  @@map("generic_submissions")
}

model SubmissionFieldValue {
  id           String    @id @default(cuid())
  submissionId String    @map("submission_id")
  fieldId      String    @map("field_id")
  textValue    String?   @map("text_value") @db.Text
  numberValue  Float?    @map("number_value")
  boolValue    Boolean?  @map("bool_value")
  dateValue    DateTime? @map("date_value")
  jsonValue    Json?     @map("json_value")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  submission GenericSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field      SubmissionField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([submissionId, fieldId])
  @@index([submissionId])
  @@index([fieldId])
  @@map("submission_field_values")
}

// ── Two-Factor Authentication & Session Management ──────────

model TwoFactorAuth {
  id          String    @id @default(cuid())
  userId      String    @unique @map("user_id")
  secret      String
  isEnabled   Boolean   @default(false) @map("is_enabled")
  backupCodes String[]  @default([]) @map("backup_codes")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

// ── User Session Tracking ─────────────────────────────────────


model UserSession {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  deviceInfo     String?  @map("device_info")
  ipAddress      String?  @map("ip_address")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActivityAt])
  @@map("user_sessions")
}
