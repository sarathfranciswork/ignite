  @@unique([boardId, organizationId])
  @@index([boardId])
  @@index([columnId])
  @@index([organizationId])
  @@index([boardId, columnId, sortOrder])
  @@map("scouting_board_cards")
}

model ScoutingBoardShare {
  id       String                 @id @default(cuid())
  boardId  String                 @map("board_id")
  userId   String                 @map("user_id")
  role     ScoutingBoardShareRole @default(VIEWER)
  sharedAt DateTime               @default(now()) @map("shared_at")

  board ScoutingBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
  @@map("scouting_board_shares")
}

// ── Scouting Mission Models ───────────────────────────────────

enum ScoutingMissionStatus {
