enum EvaluationSessionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("evaluation_session_status")
}

enum EvaluationSessionType {
  SCORECARD
  PAIRWISE
  AD_HOC
  ONE_TEAM

  @@map("evaluation_session_type")
}

enum EvaluationMode {
  STANDARD
  AD_HOC
  ONE_TEAM

  @@map("evaluation_mode")
}

enum CriterionFieldType {
  SELECTION_SCALE
  TEXT
  CHECKBOX

  @@map("criterion_field_type")
}

model EvaluationSession {
  id          String                  @id @default(cuid())
  campaignId  String?                 @map("campaign_id")
  title       String
  description String?                 @db.Text
  type        EvaluationSessionType
  mode        EvaluationMode          @default(STANDARD)
  status      EvaluationSessionStatus @default(DRAFT)
  dueDate     DateTime?               @map("due_date")
  isTemplate  Boolean                 @default(false) @map("is_template")
  templateId  String?                 @map("template_id")

  // One-Team collaborative fields
  isCollaborative    Boolean   @default(false) @map("is_collaborative")
  facilitatorId      String?   @map("facilitator_id")
  facilitator        User?     @relation("EvalSessionFacilitator", fields: [facilitatorId], references: [id], onDelete: SetNull)
  consensusRequired  Boolean   @default(false) @map("consensus_required")
  liveSessionStarted DateTime? @map("live_session_started")
  liveSessionEnded   DateTime? @map("live_session_ended")

  // Shortlist management
  shortlistLocked     Boolean   @default(false) @map("shortlist_locked")
  shortlistLockedAt   DateTime? @map("shortlist_locked_at")
  shortlistLockedById String?   @map("shortlist_locked_by_id")
  shortlistLockedBy   User?     @relation("EvalSessionShortlistLocker", fields: [shortlistLockedById], references: [id], onDelete: SetNull)

  // References
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  campaign            Campaign?                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  criteria            EvaluationCriterion[]
  evaluators          EvaluationSessionEvaluator[]
  ideas               EvaluationSessionIdea[]
  responses           EvaluationResponse[]
  pairwiseComparisons PairwiseComparison[]
  shortlistItems      EvaluationShortlistItem[]
  consensusNotes      ConsensusNote[]

  @@index([campaignId])
  @@index([status])
  @@index([mode])
  @@index([createdById])
  @@index([campaignId, status])
  @@map("evaluation_sessions")
}

model EvaluationCriterion {
  id           String             @id @default(cuid())
  sessionId    String             @map("session_id")
  title        String
  description  String?            @db.Text
  guidanceText String?            @map("guidance_text") @db.Text
  fieldType    CriterionFieldType @map("field_type")
  weight       Float              @default(1.0)
  sortOrder    Int                @default(0) @map("sort_order")
  isRequired   Boolean            @default(true) @map("is_required")

  // Selection scale config (min/max for SELECTION_SCALE type)
  scaleMin    Int?  @map("scale_min")
  scaleMax    Int?  @map("scale_max")
  scaleLabels Json? @map("scale_labels") // e.g., { "1": "Poor", "5": "Excellent" }

  // Conditional visibility
  visibleWhen Json? @map("visible_when") // e.g., { "criterionId": "xxx", "value": "true" }

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  session             EvaluationSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses           EvaluationResponse[]
  pairwiseComparisons PairwiseComparison[]

  @@index([sessionId])
  @@index([sessionId, sortOrder])
  @@map("evaluation_criteria")
}

model EvaluationSessionEvaluator {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  // Relations
  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("evaluation_session_evaluators")
}

model EvaluationSessionIdea {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  ideaId    String?  @map("idea_id")
  sortOrder Int      @default(0) @map("sort_order")
  addedAt   DateTime @default(now()) @map("added_at")

  // Ad-hoc item fields (used when ideaId is null)
  adHocTitle       String? @map("ad_hoc_title")
  adHocDescription String? @map("ad_hoc_description") @db.Text

  // Relations
  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  idea    Idea?             @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([sessionId, ideaId])
  @@index([sessionId])
  @@index([ideaId])
  @@map("evaluation_session_ideas")
}

model EvaluationResponse {
  id          String @id @default(cuid())
  sessionId   String @map("session_id")
  criterionId String @map("criterion_id")
  evaluatorId String @map("evaluator_id")
  ideaId      String @map("idea_id")

  // Response value (polymorphic based on criterion field type)
  scoreValue Int?     @map("score_value") // For SELECTION_SCALE
  textValue  String?  @map("text_value") @db.Text // For TEXT
  boolValue  Boolean? @map("bool_value") // For CHECKBOX

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  session   EvaluationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterion EvaluationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, criterionId, evaluatorId, ideaId])
  @@index([sessionId])
  @@index([evaluatorId])
  @@index([ideaId])
  @@index([sessionId, ideaId])
  @@index([sessionId, evaluatorId])
  @@map("evaluation_responses")
}

// ── Evaluation Shortlist Model ─────────────────────────────────

enum ShortlistForwardTarget {
  SELECTED_IMPLEMENTATION
  CONCEPT
  ARCHIVED

  @@map("shortlist_forward_target")
}

model EvaluationShortlistItem {
  id          String                  @id @default(cuid())
  sessionId   String                  @map("session_id")
  ideaId      String                  @map("idea_id")
  addedById   String                  @map("added_by_id")
  addedBy     User                    @relation("ShortlistItemAddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  addedAt     DateTime                @default(now()) @map("added_at")
  forwardedTo ShortlistForwardTarget? @map("forwarded_to")
  forwardedAt DateTime?               @map("forwarded_at")

  // Relations
  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  idea    Idea              @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([sessionId, ideaId])
  @@index([sessionId])
  @@index([ideaId])
  @@map("evaluation_shortlist_items")
}

// ── Pairwise Comparison Model ──────────────────────────────────

model PairwiseComparison {
  id          String @id @default(cuid())
  sessionId   String @map("session_id")
  evaluatorId String @map("evaluator_id")
  criterionId String @map("criterion_id")
  ideaAId     String @map("idea_a_id")
  ideaBId     String @map("idea_b_id")

  // Slider score: positive = ideaA preferred, negative = ideaB preferred, 0 = tie
  score Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  session   EvaluationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterion EvaluationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  ideaA     Idea                @relation("PairwiseIdeaA", fields: [ideaAId], references: [id])
  ideaB     Idea                @relation("PairwiseIdeaB", fields: [ideaBId], references: [id])

  @@unique([sessionId, evaluatorId, criterionId, ideaAId, ideaBId])
  @@index([sessionId])
  @@index([sessionId, evaluatorId])
  @@map("pairwise_comparisons")
}

