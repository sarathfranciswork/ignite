  userId     String          @map("user_id")
  role       UseCaseTeamRole @default(MEMBER)
  assignedAt DateTime        @default(now()) @map("assigned_at")

  useCase UseCase @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([useCaseId, userId])
  @@index([useCaseId])
  @@index([userId])
  @@map("use_case_team_members")
}

model UseCaseOrganization {
  id             String @id @default(cuid())
  useCaseId      String @map("use_case_id")
  organizationId String @map("organization_id")

  useCase      UseCase      @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([useCaseId, organizationId])
  @@index([useCaseId])
  @@index([organizationId])
  @@map("use_case_organizations")
}

model UseCaseTask {
  id          String            @id @default(cuid())
  useCaseId   String            @map("use_case_id")
  title       String
  description String?           @db.Text
  status      UseCaseTaskStatus @default(OPEN)
  assigneeId  String?           @map("assignee_id")
  dueDate     DateTime?         @map("due_date")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  useCase  UseCase @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  assignee User?   @relation("UseCaseTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([useCaseId])
  @@index([assigneeId])
  @@index([useCaseId, status])
  @@map("use_case_tasks")
}

