// ── Phase-Gate Projects ─────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  TERMINATED

  @@map("project_status")
}

enum ProjectTeamRole {
  LEADER
  MEMBER
  GATEKEEPER

  @@map("project_team_role")
}

enum ProcessFieldType {
  TEXT
  NUMBER
  KEYWORD
  ATTACHMENT
  DATE
  USER

  @@map("process_field_type")
}

model ProcessDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User           @relation("ProcessDefinitionCreatedBy", fields: [createdById], references: [id])
  phases    ProcessPhase[]
  projects  Project[]

  @@index([createdById])
  @@map("process_definitions")
}

model ProcessPhase {
  id                  String   @id @default(cuid())
  processDefinitionId String   @map("process_definition_id")
  name                String
  description         String?  @db.Text
  plannedDurationDays Int?     @map("planned_duration_days")
  position            Int
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  processDefinition ProcessDefinition       @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  activities        ProcessPhaseActivity[]
  currentProjects   Project[]               @relation("ProjectCurrentPhase")
  phaseInstances    ProjectPhaseInstance[]
  taskAssignments   ProjectTaskAssignment[] @relation("ProjectTaskAssignmentPhase")

  @@index([processDefinitionId])
  @@map("process_phases")
}

model ProcessPhaseActivity {
  id          String   @id @default(cuid())
  phaseId     String   @map("phase_id")
  name        String
  description String?  @db.Text
  isMandatory Boolean  @default(false) @map("is_mandatory")
  position    Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  phase ProcessPhase               @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  tasks ProcessPhaseActivityTask[]

  @@index([phaseId])
  @@map("process_phase_activities")
}

model ProcessPhaseActivityTask {
  id          String           @id @default(cuid())
  activityId  String           @map("activity_id")
  name        String
  fieldType   ProcessFieldType @map("field_type")
  isMandatory Boolean          @default(false) @map("is_mandatory")
  position    Int
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  activity    ProcessPhaseActivity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  assignments ProjectTaskAssignment[]

  @@index([activityId])
  @@map("process_phase_activity_tasks")
}

model Project {
  id                  String        @id @default(cuid())
  title               String
  description         String?       @db.Text
  processDefinitionId String        @map("process_definition_id")
  status              ProjectStatus @default(ACTIVE)
  currentPhaseId      String?       @map("current_phase_id")
  isConfidential      Boolean       @default(false) @map("is_confidential")
  createdById         String        @map("created_by_id")
  sourceIdeaId        String?       @map("source_idea_id")
  sourceConceptId     String?       @unique @map("source_concept_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  processDefinition ProcessDefinition       @relation(fields: [processDefinitionId], references: [id])
  currentPhase      ProcessPhase?           @relation("ProjectCurrentPhase", fields: [currentPhaseId], references: [id], onDelete: SetNull)
  createdBy         User                    @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  sourceIdea        Idea?                   @relation("ProjectSourceIdea", fields: [sourceIdeaId], references: [id], onDelete: SetNull)
  sourceConcept     Concept?                @relation("ProjectSourceConcept", fields: [sourceConceptId], references: [id], onDelete: SetNull)
  teamMembers       ProjectTeamMember[]
  phaseInstances    ProjectPhaseInstance[]
  taskAssignments   ProjectTaskAssignment[]

  @@index([processDefinitionId])
  @@index([createdById])
  @@index([sourceIdeaId])
  @@index([sourceConceptId])
  @@index([status])
  @@map("projects")
}

model ProjectTeamMember {
  id        String          @id @default(cuid())
  projectId String          @map("project_id")
  userId    String          @map("user_id")
  role      ProjectTeamRole
  createdAt DateTime        @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectTeamMember", fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_team_members")
}

// ── Project Task Assignments ────────────────────────────────

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED

  @@map("project_task_status")
}

model ProjectTaskAssignment {
  id           String            @id @default(cuid())
  projectId    String            @map("project_id")
  taskId       String            @map("task_id")
  phaseId      String            @map("phase_id")
  assigneeId   String?           @map("assignee_id")
  status       ProjectTaskStatus @default(TODO)
  dueDate      DateTime?         @map("due_date")
  textValue    String?           @map("text_value") @db.Text
  numberValue  Float?            @map("number_value")
  dateValue    DateTime?         @map("date_value")
  keywordValue String[]          @default([]) @map("keyword_value")
  fileUrl      String?           @map("file_url")
  userValue    String?           @map("user_value")
  completedAt  DateTime?         @map("completed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project  Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     ProcessPhaseActivityTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  phase    ProcessPhase             @relation("ProjectTaskAssignmentPhase", fields: [phaseId], references: [id])
  assignee User?                    @relation("ProjectTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@unique([projectId, taskId])
  @@index([projectId])
  @@index([taskId])
  @@index([phaseId])
  @@index([assigneeId])
  @@index([status])
  @@map("project_task_assignments")
}

// ── Phase Lifecycle & Gate Decisions ────────────────────────

enum PhaseInstanceStatus {
  ELABORATION
  GATE_REVIEW
  COMPLETED
  SKIPPED

  @@map("phase_instance_status")
}

enum GateDecisionType {
  FORWARD
  REWORK
  POSTPONE
  TERMINATE

  @@map("gate_decision_type")
}

model ProjectPhaseInstance {
  id             String              @id @default(cuid())
  projectId      String              @map("project_id")
  phaseId        String              @map("phase_id")
  position       Int
  status         PhaseInstanceStatus @default(ELABORATION)
  plannedStartAt DateTime?           @map("planned_start_at")
  plannedEndAt   DateTime?           @map("planned_end_at")
  actualStartAt  DateTime?           @map("actual_start_at")
  actualEndAt    DateTime?           @map("actual_end_at")
  reworkFeedback String?             @map("rework_feedback") @db.Text
  postponeUntil  DateTime?           @map("postpone_until")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase         ProcessPhase   @relation(fields: [phaseId], references: [id])
  gateDecisions GateDecision[]

  @@unique([projectId, phaseId])
  @@index([projectId])
  @@index([phaseId])
  @@index([status])
  @@map("project_phase_instances")
}

model GateDecision {
  id              String           @id @default(cuid())
  phaseInstanceId String           @map("phase_instance_id")
  gatekeeperId    String           @map("gatekeeper_id")
  decision        GateDecisionType
  feedback        String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")

  phaseInstance ProjectPhaseInstance @relation(fields: [phaseInstanceId], references: [id], onDelete: Cascade)
  gatekeeper    User                 @relation("GateDecisionGatekeeper", fields: [gatekeeperId], references: [id])

  @@index([phaseInstanceId])
  @@index([gatekeeperId])
  @@map("gate_decisions")
}

// ── SCIM Provisioning Models ─────────────────────────────────

model ScimToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @map("token_hash")
  createdById String    @map("created_by_id")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

