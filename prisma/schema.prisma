// ── Activity Stream Models ──────────────────────────────────

enum ActivityEventType {
  IDEA_SUBMITTED
  IDEA_TRANSITIONED
  IDEA_STATUS_CHANGED
  IDEA_ARCHIVED
  IDEA_UNARCHIVED
  COMMENT_CREATED
  IDEA_LIKED
  IDEA_VOTED
  IDEA_FOLLOWED
  IDEA_COACH_QUALIFIED
  IDEA_COACH_REJECTED
  IDEA_COACH_REQUESTED_CHANGES
  IDEA_SPLIT
  IDEA_MERGED
  IDEA_BULK_ARCHIVED
  IDEA_BULK_BUCKET_ASSIGNED
  IDEA_BULK_EXPORTED

  @@map("activity_event_type")
}

model ActivityEvent {
  id         String            @id @default(cuid())
  ideaId     String            @map("idea_id")
  campaignId String            @map("campaign_id")
  actorId    String            @map("actor_id")
  eventType  ActivityEventType @map("event_type")
  title      String
