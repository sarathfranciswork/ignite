  invitationStatus InvitationStatus @default(NOT_INVITED) @map("invitation_status")
  linkedUserId     String?          @map("linked_user_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedUser   User?        @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([linkedUserId])
  @@map("contacts")
}

// ── Use Case Pipeline Models ──────────────────────────────────

enum UseCaseStatus {
  IDENTIFIED
  QUALIFICATION
  EVALUATION
  PILOT
  PARTNERSHIP
  ARCHIVED

  @@map("use_case_status")
}

enum UseCaseTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED

  @@map("use_case_task_status")
}

enum UseCaseTeamRole {
  LEAD
  MEMBER

  @@map("use_case_team_role")
}

model UseCase {
  id                 String         @id @default(cuid())
  title              String
  problemDescription String?        @map("problem_description") @db.Text
  suggestedSolution  String?        @map("suggested_solution") @db.Text
  benefit            String?        @db.Text
  status             UseCaseStatus  @default(IDENTIFIED)
  previousStatus     UseCaseStatus? @map("previous_status")
  ownerId            String         @map("owner_id")
  createdById        String         @map("created_by_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  owner         User                  @relation("UseCaseOwner", fields: [ownerId], references: [id])
  createdBy     User                  @relation("UseCaseCreatedBy", fields: [createdById], references: [id])
  teamMembers   UseCaseTeamMember[]
  organizations UseCaseOrganization[]
  tasks         UseCaseTask[]

  @@index([status])
  @@index([ownerId])
  @@index([createdById])
