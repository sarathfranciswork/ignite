generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js Models ────────────────────────────────────────────

enum GlobalRole {
  PLATFORM_ADMIN
  INNOVATION_MANAGER
  MEMBER

  @@map("global_role")
}

enum NotificationFrequency {
  IMMEDIATE
  DAILY
  WEEKLY

  @@map("notification_frequency")
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  emailVerified         DateTime?             @map("email_verified")
  name                  String?
  image                 String?
  password              String?
  globalRole            GlobalRole            @default(MEMBER) @map("global_role")
  isActive              Boolean               @default(true) @map("is_active")
  bio                   String?               @db.Text
  skills                String[]              @default([])
  notificationFrequency NotificationFrequency @default(IMMEDIATE) @map("notification_frequency")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  userGroupMembership UserGroupMembership[]
  orgUnitAssignments  UserOrgUnit[]
  createdCampaigns    Campaign[]                  @relation("CampaignCreatedBy")
  campaignMemberships CampaignMember[]
  createdChannels     Channel[]                   @relation("ChannelCreatedBy")
  channelMemberships  ChannelMember[]
  spaceMemberships    InnovationSpaceMembership[]
  contributedIdeas    Idea[]                      @relation("IdeaContributor")
  coAuthoredIdeas     IdeaCoAuthor[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Resource Role Models ──────────────────────────────────────

enum ResourceRoleType {
  CAMPAIGN_MANAGER
  CAMPAIGN_COACH
  CAMPAIGN_CONTRIBUTOR
  CAMPAIGN_MODERATOR
  CAMPAIGN_EVALUATOR
  CAMPAIGN_SEEDER
  CAMPAIGN_SPONSOR
  CHANNEL_MANAGER
  CHANNEL_CONTRIBUTOR

  @@map("resource_role_type")
}

enum CoachAssignmentMode {
  GLOBAL
  PER_CATEGORY

  @@map("coach_assignment_mode")
}

model ResourceRole {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  resourceId   String           @map("resource_id")
  resourceType String           @map("resource_type") // "campaign" or "channel"
  role         ResourceRoleType
  assignedAt   DateTime         @default(now()) @map("assigned_at")
  assignedBy   String?          @map("assigned_by")

  @@unique([userId, resourceId, role])
  @@index([userId])
  @@index([resourceId])
  @@map("resource_roles")
}

// ── Organizational Models ─────────────────────────────────────

model OrgUnit {
  id          String   @id @default(cuid())
  name        String
  description String?
  parentId    String?  @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent          OrgUnit?      @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children        OrgUnit[]     @relation("OrgUnitHierarchy")
  userAssignments UserOrgUnit[]

  @@map("org_units")
}

model UserOrgUnit {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  orgUnitId  String   @map("org_unit_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgUnit OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@unique([userId, orgUnitId])
  @@index([userId])
  @@index([orgUnitId])
  @@map("user_org_units")
}

model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members UserGroupMembership[]

  @@map("user_groups")
}

model UserGroupMembership {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  groupId  String   @map("group_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("user_group_memberships")
}

// ── Innovation Space Models ──────────────────────────────────

enum SpaceStatus {
  ACTIVE
  ARCHIVED

  @@map("space_status")
}

enum SpaceRole {
  SPACE_ADMIN
  SPACE_MANAGER
  SPACE_MEMBER

  @@map("space_role")
}

model InnovationSpace {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  slug        String      @unique
  logoUrl     String?     @map("logo_url")
  status      SpaceStatus @default(ACTIVE)
  settings    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  memberships InnovationSpaceMembership[]

  @@index([status])
  @@index([slug])
  @@map("innovation_spaces")
}

model InnovationSpaceMembership {
  id       String    @id @default(cuid())
  spaceId  String    @map("space_id")
  userId   String    @map("user_id")
  role     SpaceRole @default(SPACE_MEMBER)
  joinedAt DateTime  @default(now()) @map("joined_at")

  space InnovationSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
  @@map("innovation_space_memberships")
}

// ── Campaign Models ──────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SEEDING
  SUBMISSION
  DISCUSSION_VOTING
  EVALUATION
  CLOSED

  @@map("campaign_status")
}

enum SubmissionType {
  CALL_FOR_IDEAS
  CALL_FOR_PROPOSALS
  CALL_FOR_GENERIC

  @@map("submission_type")
}

enum SetupType {
  SIMPLE
  ADVANCED

  @@map("setup_type")
}

enum AudienceType {
  ALL_INTERNAL
  SELECTED_INTERNAL
  ALL_EXTERNAL
  SELECTED_EXTERNAL
  MIXED

  @@map("audience_type")
}

model Campaign {
  id             String          @id @default(cuid())
  title          String
  teaser         String?
  description    String?         @db.Text
  bannerUrl      String?         @map("banner_url")
  videoUrl       String?         @map("video_url")
  status         CampaignStatus  @default(DRAFT)
  previousStatus CampaignStatus? @map("previous_status")
  submissionType SubmissionType  @default(CALL_FOR_IDEAS) @map("submission_type")
  setupType      SetupType       @default(SIMPLE) @map("setup_type")
  audienceType   AudienceType    @default(ALL_INTERNAL) @map("audience_type")

  // Timeline
  submissionCloseDate DateTime? @map("submission_close_date")
  votingCloseDate     DateTime? @map("voting_close_date")
  plannedCloseDate    DateTime? @map("planned_close_date")
  launchedAt          DateTime? @map("launched_at")
  closedAt            DateTime? @map("closed_at")

  // Feature toggles
  hasSeedingPhase        Boolean @default(true) @map("has_seeding_phase")
  hasDiscussionPhase     Boolean @default(true) @map("has_discussion_phase")
  hasCommunityGraduation Boolean @default(true) @map("has_community_graduation")
  hasQualificationPhase  Boolean @default(false) @map("has_qualification_phase")
  hasVoting              Boolean @default(false) @map("has_voting")
  hasLikes               Boolean @default(true) @map("has_likes")
  hasIdeaCoach           Boolean @default(false) @map("has_idea_coach")
  isConfidentialAllowed  Boolean @default(false) @map("is_confidential_allowed")
  isFeatured             Boolean @default(false) @map("is_featured")
  isShowOnStartPage      Boolean @default(true) @map("is_show_on_start_page")

  // Idea Coach settings
  coachAssignmentMode CoachAssignmentMode @default(GLOBAL) @map("coach_assignment_mode")
  ideaCategories      Json?               @map("idea_categories")

  // Community graduation thresholds
  graduationVisitors     Int   @default(10) @map("graduation_visitors")
  graduationCommenters   Int   @default(5) @map("graduation_commenters")
  graduationLikes        Int   @default(0) @map("graduation_likes")
  graduationVoters       Int   @default(0) @map("graduation_voters")
  graduationVotingLevel  Float @default(0) @map("graduation_voting_level")
  graduationDaysInStatus Int   @default(0) @map("graduation_days_in_status")

  // Settings stored as JSON
  votingCriteria Json? @map("voting_criteria")
  customFields   Json? @map("custom_fields")
  settings       Json?

  // References
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy    User                  @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  members      CampaignMember[]
  kpiSnapshots CampaignKpiSnapshot[]
  ideas        Idea[]

  @@index([status])
  @@index([submissionType])
  @@index([createdById])
  @@map("campaigns")
}

model CampaignMember {
  id         String           @id @default(cuid())
  campaignId String           @map("campaign_id")
  userId     String           @map("user_id")
  role       ResourceRoleType
  category   String?
  assignedAt DateTime         @default(now()) @map("assigned_at")
  assignedBy String?          @map("assigned_by")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, role])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_members")
}

// ── KPI Snapshot Models ─────────────────────────────────────

model CampaignKpiSnapshot {
  id           String   @id @default(cuid())
  campaignId   String   @map("campaign_id")
  snapshotDate DateTime @map("snapshot_date")

  // Engagement metrics
  totalViews        Int @default(0) @map("total_views")
  uniqueVisitors    Int @default(0) @map("unique_visitors")
  totalParticipants Int @default(0) @map("total_participants")

  // Idea funnel
  ideasSubmitted Int @default(0) @map("ideas_submitted")
  ideasQualified Int @default(0) @map("ideas_qualified")
  ideasHot       Int @default(0) @map("ideas_hot")
  ideasEvaluated Int @default(0) @map("ideas_evaluated")
  ideasSelected  Int @default(0) @map("ideas_selected")

  // Activity counters
  totalComments Int @default(0) @map("total_comments")
  totalVotes    Int @default(0) @map("total_votes")
  totalLikes    Int @default(0) @map("total_likes")

  createdAt DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, snapshotDate])
  @@index([campaignId])
  @@index([snapshotDate])
  @@map("campaign_kpi_snapshots")
}

// ── Channel Models ──────────────────────────────────────────

enum ChannelStatus {
  ACTIVE
  ARCHIVED

  @@map("channel_status")
}

model Channel {
  id               String        @id @default(cuid())
  title            String
  teaser           String?
  description      String?       @db.Text
  problemStatement String?       @map("problem_statement") @db.Text
  bannerUrl        String?       @map("banner_url")
  status           ChannelStatus @default(ACTIVE)

  // Feature toggles (subset of campaign toggles — no seeding, no timeline)
  hasQualificationPhase Boolean @default(false) @map("has_qualification_phase")
  hasDiscussionPhase    Boolean @default(true) @map("has_discussion_phase")
  hasVoting             Boolean @default(false) @map("has_voting")
  hasLikes              Boolean @default(true) @map("has_likes")

  // Settings stored as JSON
  votingCriteria Json? @map("voting_criteria")
  customFields   Json? @map("custom_fields")
  settings       Json?

  // References
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy User            @relation("ChannelCreatedBy", fields: [createdById], references: [id])
  members   ChannelMember[]

  @@index([status])
  @@index([createdById])
  @@map("channels")
}

model ChannelMember {
  id         String           @id @default(cuid())
  channelId  String           @map("channel_id")
  userId     String           @map("user_id")
  role       ResourceRoleType
  assignedAt DateTime         @default(now()) @map("assigned_at")
  assignedBy String?          @map("assigned_by")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId, role])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

// ── Idea Models ─────────────────────────────────────────────

enum IdeaStatus {
  DRAFT
  QUALIFICATION
  COMMUNITY_DISCUSSION
  HOT
  EVALUATION
  SELECTED_IMPLEMENTATION
  IMPLEMENTED
  ARCHIVED

  @@map("idea_status")
}

model Idea {
  id             String     @id @default(cuid())
  title          String
  teaser         String?    @db.Text
  description    String?    @db.Text
  status         IdeaStatus @default(DRAFT)
  previousStatus IdeaStatus? @map("previous_status")

  // Campaign association
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Contributor (author)
  contributorId String @map("contributor_id")
  contributor   User   @relation("IdeaContributor", fields: [contributorId], references: [id])

  // Content
  category           String?
  tags               String[]  @default([])
  customFieldValues  Json?     @map("custom_field_values")
  attachments        Json?
  isConfidential     Boolean   @default(false) @map("is_confidential")
  inventionDisclosure Boolean  @default(false) @map("invention_disclosure")

  // Full-text search vector (populated via database trigger)
  searchVector  Unsupported("tsvector")? @map("search_vector")

  // Engagement counters (denormalized for performance)
  likesCount    Int @default(0) @map("likes_count")
  commentsCount Int @default(0) @map("comments_count")
  viewsCount    Int @default(0) @map("views_count")

  // Timestamps
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  coAuthors IdeaCoAuthor[]

  @@index([campaignId])
  @@index([contributorId])
  @@index([status])
  @@index([campaignId, status])
  @@index([searchVector], type: Gin)
  @@map("ideas")
}

model IdeaCoAuthor {
  id     String @id @default(cuid())
  ideaId String @map("idea_id")
  userId String @map("user_id")

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@index([userId])
  @@map("idea_co_authors")
}
